# Anthropic Claude API key — powers the chat model in /api/chat
ANTHROPIC_API_KEY=

# OpenAI API key — used to embed the user query for product retrieval AND to
# synthesize speech for voice mode (/api/tts).
OPENAI_API_KEY=

# --- Text-to-speech (voice mode, /api/tts) ----------------------------------
# OpenAI TTS model. Default gpt-4o-mini-tts (current cost-efficient model,
# multilingual, ~$15.9 / 1M characters as of 2026-06). The `instructions`
# steering below is only sent for gpt-4o(-mini)-tts; legacy tts-1 / tts-1-hd
# ignore/reject it, so it's gated on the model family in code.
TTS_MODEL=gpt-4o-mini-tts

# TTS voice. Default "alloy" — neutral, gender-neutral, clean German
# pronunciation. Warmer alternatives: nova, coral, shimmer. Full set: alloy,
# ash, ballad, coral, echo, fable, onyx, nova, sage, shimmer, verse, marin, cedar.
TTS_VOICE=alloy

# Optional tone/accent steering for gpt-4o(-mini)-tts. Defaults to a natural
# Hochdeutsch instruction; set empty or override to change the speaking style.
TTS_INSTRUCTIONS=

# Comma-separated list of browser origins allowed to call the API
# (CORS allowlist). Falls back to https://www.motionsports.de,https://motionsports.de
ALLOWED_ORIGINS=https://www.motionsports.de,https://motionsports.de

# Shared secret the frontend must send in the `x-ms-chat-key` header
# on every /api/chat and /api/contact request. Generate a long random string.
CHAT_SHARED_SECRET=

# --- Upstash Redis (rate limiting) ------------------------------------------
# Connection for the per-client rate limiter (sliding-window buckets, e.g.
# 20 chat requests / 60 s). Vercel's Upstash Marketplace integration injects
# these two automatically under the KV_* names — you normally do NOT set them by
# hand in production. REQUIRED: the rate limiter builds its Redis client from
# EXACTLY these names and fails fast (loud error, no silent no-op) if either is
# missing, so a misconfiguration can never quietly disable rate limiting.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend API key — used by /api/contact to deliver contact-form submissions
# as email. If unset, submissions are logged to stdout (local dev fallback).
RESEND_API_KEY=

# Inbox that receives contact-form submissions (e.g. vertrieb@motionsports.de).
# Must be set together with RESEND_API_KEY for email to be sent.
CONTACT_TO_EMAIL=

# Verified Resend sender (e.g. "Motion Sports <kontakt@motionsports.de>").
# The domain must be verified in your Resend dashboard. ALSO used as the
# "from" address for the email-capture flow (summary, DOI confirmation).
CONTACT_FROM_EMAIL=

# --- Email capture + double opt-in (GDPR) -----------------------------------
# Public base URL of THIS backend, used to build the absolute links that go
# into emails (DOI confirmation, unsubscribe). e.g. https://chat.motionsports.de
# If unset, the backend falls back to Vercel's injected host, then the request
# origin. Set it explicitly in production so links are always correct.
PUBLIC_BASE_URL=

# Days a marketing double-opt-in (DOI) confirmation token stays valid, measured
# from when it was sent. After this, /api/confirm-marketing rejects it. Default 7.
MARKETING_DOI_EXPIRY_DAYS=7

# Secret used to sign the email-keyed unsubscribe links (HMAC-SHA256). If unset,
# CHAT_SHARED_SECRET is used as a fallback. Set a dedicated long random string so
# rotating the chat secret doesn't invalidate every outstanding unsubscribe link.
UNSUBSCRIBE_SECRET=

# --- Inbound email (Resend Inbound — receive replies) -----------------------
# The unified mail log (email_messages, migration 0021) + the inbound webhook
# /api/inbound/resend. See docs/EMAIL_SUBSYSTEM_SPIKE.md.

# The DEDICATED address Resend Inbound receives replies on (currently a TEST
# address; the production swap is env-only — never hardcoded). Point its MX at
# Resend and verify the domain. Set as Reply-To on every outbound mail so a
# customer's reply routes to inbound and threads back. Use a dedicated inbound
# subdomain, e.g. bot@chat.motionsports.de — NOT the corporate MX / kontakt@
# sender. If unset, outbound mail simply omits the Reply-To (no behaviour change).
INBOUND_EMAIL_ADDRESS=

# Svix signing secret (whsec_…) for the Resend Inbound webhook. The route
# verifies every payload's signature over the RAW body BEFORE parsing; without
# this set, /api/inbound/resend fails closed (503) and ingests nothing.
RESEND_WEBHOOK_SECRET=

# Server-side switch for the returning-customer hint served alongside the
# capture-form consent copy (returningHint.enabled in GET /api/consent-copy
# and the offer_email_summary tool result). DEFAULT TRUE; set false to make
# the widget hide the hint without a theme release.
RETURNING_HINT_ENABLED=true

# --- Physical mail (Pingen → Deutsche Post) ---------------------------------
# The physical-letter channel (physical_letters, migration 0022) + the Pingen
# REST client (lib/pingen) + the status webhook /api/webhooks/pingen. There is
# NO JS/TS Pingen SDK — we call the REST API directly. See
# docs/EMAIL_SUBSYSTEM_SPIKE.md §4.

# OAuth2 client_credentials app (identity.pingen.com → api.pingen.com), scoped
# by the organisation UUID. Create a Developer App in the Pingen dashboard.
PINGEN_CLIENT_ID=
PINGEN_CLIENT_SECRET=
PINGEN_ORGANISATION_ID=

# Use the FREE staging environment (api-staging.pingen.com /
# identity-staging.pingen.com), which mirrors production for end-to-end tests.
# Any of 1/true/yes/on selects staging; default (unset) is PRODUCTION.
PINGEN_STAGING=true

# Standard-webhooks signing secret(s) (whsec_…) for the Pingen status webhook.
# The route verifies every payload over the RAW body BEFORE parsing; without this
# set, /api/webhooks/pingen fails closed (503) and ingests nothing.
# Pingen issues a SEPARATE secret per event-type subscription (Sent / Delivered /
# Undeliverable / Document Issues), all pointing at the same webhook URL — so set
# a COMMA-SEPARATED LIST of all of them here (an event verifies if it matches any
# one). A single shared secret across all subscriptions also works.
#   e.g. PINGEN_WEBHOOK_SECRET=whsec_aaa,whsec_bbb,whsec_ccc,whsec_ddd
PINGEN_WEBHOOK_SECRET=

# Sign-off gate for REAL physical sends — Pingen is a NEW DATA PROCESSOR
# (recipient address → Pingen/CH → Deutsche Post) needing its own AV-Vertrag
# (DPA) + a CH third-country transfer note. The whole physical-send path (client,
# table, PDF render, webhook) is BUILT regardless, and stays OFF (fail-closed,
# default false) until sign-off. APPROVED by Legal (2026-06-14) → enabled. NB:
# this value is the documented default; the EFFECTIVE switch is the env var in
# your deployment (Vercel project + local .env) — set it there too. Only
# 1/true/yes/on enable it. SEPARATE from CONSENT_COPY_LAWYER_APPROVED.
PHYSICAL_MAIL_SENDS_APPROVED=true

# How long physical_letters rows are kept (audit), in days (default 365). Its
# own category (a letter is NOT email); purged by /api/cron/retention.
PHYSICAL_LETTER_RETENTION_DAYS=365

# Fallback postage cost per letter in CENTS, used in the KPI cost total when
# Pingen hasn't reported a price for a letter (e.g. staging). Default 106 (1,06 €).
PINGEN_LETTER_COST_CENTS=106

# --- Admin marketing dashboard ----------------------------------------------
# Single shared password protecting /admin and /api/admin/*. The login server
# action checks the submitted password against this (constant-time) and, on
# success, sets a signed HTTP-only session cookie. If unset, the admin login is
# disabled (fails closed). Use a long, random passphrase.
ADMIN_PASSWORD=

# Secret used to HMAC-sign the admin session cookie. Prefer a dedicated long
# random string; if unset, CHAT_SHARED_SECRET is used as a fallback. Rotating
# this invalidates all outstanding admin sessions.
ADMIN_SESSION_SECRET=

# Days a generated single-use marketing discount code stays valid (endsAt =
# mint time + N days). Default 7. The marketing email states this validity
# period and the concrete expiry date next to the call-to-action.
MARKETING_DISCOUNT_EXPIRY_DAYS=7

# How far back (days) the "chatted but not purchased" check looks for a Shopify
# order from a confirmed marketing contact's email. Default 180.
MARKETING_ORDER_LOOKBACK_DAYS=180

# Per-recipient marketing send-frequency cap: minimum days between two marketing
# emails to the SAME address (approveAndSend refuses an earlier re-send with
# HTTP 429). The cadence is a policy choice; default 0 = disabled (set e.g. 14).
MARKETING_MIN_SEND_INTERVAL_DAYS=0

# --- Shopify catalog sync ---------------------------------------------------
# As of January 2026 the Shopify admin no longer exposes a static shpat_
# access token. Apps created in the Developer Dashboard get a Client ID and
# Client Secret (shpss_…); the backend exchanges them for a short-lived
# Admin API token via the OAuth client-credentials grant. Run
# `npm run verify:shopify` after filling these in to confirm auth works.

# The store's *.myshopify.com domain (NOT the public domain).
# Example: motion-sports.myshopify.com
SHOPIFY_STORE_DOMAIN=

# App Client ID from the Shopify Developer Dashboard.
# Required scopes: read_products + write_products (catalog sync), and for the
# admin marketing dashboard write_discounts (code creation) + read_orders
# (the "chatted but not purchased" check). Reading an order's email is protected
# customer data — the app may also need Protected Customer Data access approved.
#
# BUNDLE OFFERS additionally require read_publications + write_publications — the
# bundle is published to the Online Store via publishablePublish, which fails
# with ACCESS_DENIED without them (for BOTH the native and the fallback path; see
# docs/BUNDLES.md). With these two added, the documented required-scope set is
# 17 scopes (the original spike listed 15). Client-credentials tokens only carry
# scopes granted at install, so REINSTALL the app on the store after adding them.
SHOPIFY_CLIENT_ID=

# App Client Secret (shpss_…) from the Shopify Developer Dashboard.
SHOPIFY_CLIENT_SECRET=

# Admin API version to target. Use the current stable, e.g. 2026-04.
# See https://shopify.dev/docs/api/usage/versioning
SHOPIFY_API_VERSION=2026-04

# --- Shopify Customer Account sign-in (tier-3 identity) ----------------------
# SEPARATE client from the Admin one above (different credentials + host). Used
# for the OAuth 2.0 authorization-code + PKCE (S256) customer sign-in. See
# docs/CUSTOMER_ACCOUNT.md and run `npm run verify:customer-account` to execute
# the verify gate (discovery + token-endpoint client auth + prompt=none).

# Customer Account API client id (PUBLIC client — this is NOT a secret; it
# appears in the browser's authorization URL by design). Get it from Shopify
# admin → Headless → Customer Account API. Set it in the deployment env; left
# blank here to match the other credential fields (and keep secret scanners
# happy — an unset example value can never be mistaken for a leaked one).
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=

# Customer Account API client SECRET — leave EMPTY for the confirmed PUBLIC
# (PKCE, no-secret) setup. Set ONLY if the verify gate reports the token
# endpoint rejected the public exchange and the client was switched to
# Confidential in Shopify admin; the backend then uses client_secret_basic.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=

# Public storefront domain that hosts the discovery documents
# (/.well-known/openid-configuration + /.well-known/customer-account-api).
# Default www.motionsports.de. The auth itself happens on the Shopify-managed
# account.<domain> subdomain (read from discovery — never hardcoded).
SHOPIFY_STOREFRONT_DOMAIN=www.motionsports.de

# Customer Account GraphQL version (fallback only — the live endpoint is read
# from discovery, which pins the version). Current: 2026-04.
SHOPIFY_CUSTOMER_ACCOUNT_API_VERSION=2026-04

# 32-byte key used to encrypt the customer OAuth tokens at rest (AES-256-GCM,
# customer_oauth_tokens). 64 hex chars, or 32-byte base64, or a 32-byte raw
# string. Generate e.g.: openssl rand -hex 32. REQUIRED for sign-in token
# storage — the callback fails closed without it.
TOKEN_ENC_KEY=

# Secret used to HMAC-sign the OAuth `state`. Prefer a dedicated long random
# string; if unset, CHAT_SHARED_SECRET is used as a fallback.
SHOPIFY_CUSTOMER_ACCOUNT_STATE_SECRET=

# How long a pending-auth record (CSRF state + PKCE verifier) stays valid
# between /api/auth/shopify/login and the callback. Default 10 (minutes).
CUSTOMER_AUTH_PENDING_TTL_MINUTES=10

# --- Catalog sync storage + scheduling --------------------------------------
# Vercel Blob token used to read/write the cached catalog + embeddings
# (keys: catalog/product-catalog.json, catalog/product-embeddings.json).
# If unset the runtime falls back to the committed JSON in src/data/.
BLOB_READ_WRITE_TOKEN=

# Shared secret Vercel Cron sends as `Authorization: Bearer <secret>` to
# /api/cron/sync-catalog, /api/cron/retention, /api/cron/expire-bundles and
# /api/cron/refresh-customers. Generate a long random string.
CRON_SECRET=

# --- Scheduled customer-data refresh (/api/cron/refresh-customers, daily) ----
# Keeps each customer's cached Shopify data (order history + lawful postal
# address) fresh automatically, so drafts are never built on stale data. Does
# NOT regenerate the paid AI profile (that stays manual). Both have sane defaults.
# Customers per run (most-stale first; daily runs sweep the whole base).
CUSTOMER_REFRESH_BATCH=25
# Only refresh a customer whose data is older than this many hours.
CUSTOMER_REFRESH_STALE_HOURS=24

# --- Bundle offers (optional — defaults are sane) ---------------------------
# Personalized bundle offers (see docs/BUNDLES.md). The "create the Shopify
# product" step is behind a seam selected by this flag:
#   native_fixed_bundle    (default) — real Shopify fixed bundle, native
#                                       component-inventory linkage. VERIFIED GO.
#   plain_unlisted_product            — fallback: a plain UNLISTED product priced
#                                       at the bundle total, components in the
#                                       description (NO native inventory linkage).
BUNDLE_CREATION_MODE=native_fixed_bundle

# Days an offer stays live before the daily cron archives it (default 7).
BUNDLE_OFFER_EXPIRY_DAYS=7

# Where the friendly "Angebot abgelaufen" page sends a late click ("Zum Shop").
# Defaults to the storefront root; set to a collection for something sharper.
BUNDLE_EXPIRED_REDIRECT_URL=

# --- Observability (optional) ----------------------------------------------
# Sentry DSN for server-side error capture — ERRORS ONLY. tracesSampleRate is
# pinned to 0 in code, so no performance/transaction events are sent (we don't
# spend the free-tier quota on traces). If unset, Sentry init is skipped cleanly
# and errors are logged to stdout only — the routes never crash on missing
# observability config, but a one-time warning is logged so a missing DSN is
# visible, not silent.
#
# This is the SINGLE Sentry DSN var (do NOT add a separate SENTRY_DSN). The
# Vercel Sentry integration injects it automatically in deployed environments;
# set it here only for local error reporting. A DSN is NOT a secret — it ships
# in client bundles by design.
NEXT_PUBLIC_SENTRY_DSN=

# Build-time only — consumed by the Sentry Next.js plugin for source-map upload
# during `next build`. The Vercel Sentry integration injects these at build time
# in CI/deploys; you do NOT need them for local dev or runtime. Listed here for
# reference (leave commented).
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- AI cost tracking (optional — KPI tab) ----------------------------------
# Token usage from every AI call (chat, email drafts, summaries, embeddings) is
# recorded and turned into a EUR "cost per consultation" on the KPI tab. Prices
# change, so the model→price table can be overridden without a code change.

# JSON object mapping model id → { input, output } in USD per MILLION tokens.
# Overrides/extends the built-in defaults (sane values for the models we use).
# Example:
#   MODEL_PRICES_JSON={"claude-sonnet-4-5-20250929":{"input":3,"output":15},"claude-opus-4-8":{"input":5,"output":25}}
# NB: TTS models (e.g. gpt-4o-mini-tts) are billed per CHARACTER, so for those
# the `input` value is USD per million CHARACTERS and `output` is 0 — the TTS
# usage rows store characters synthesized in the input column.
# Leave unset to use the built-in defaults.
MODEL_PRICES_JSON=

# USD→EUR conversion rate applied to computed costs. Default 0.92.
USD_EUR_RATE=0.92

# --- Database (Vercel Postgres / Neon) --------------------------------------
# As of 2026 Vercel Postgres is the Neon native integration. Installing it
# from the Vercel Marketplace injects these automatically — you normally do
# NOT set them by hand in production. They're listed here so local dev and the
# `npm run db:migrate` script know what to provide.
#
# Pooled connection (used by the serverless routes for short queries). The
# integration also injects the legacy POSTGRES_URL with the same value.
DATABASE_URL=

# Direct/unpooled connection (used by migrations and other DDL-heavy work).
# The integration also injects the legacy POSTGRES_URL_NON_POOLING. If unset,
# the pooled URL is used as a fallback.
DATABASE_URL_UNPOOLED=

# --- Data retention (optional — sensible defaults baked in) ------------------
# Enforced daily by /api/cron/retention (protected by the existing CRON_SECRET
# above). See docs/DATA_RETENTION.md. All values are in days except the
# abandonment window (minutes). Leave unset to use the defaults shown.

# Conversations + messages older than this (by last_activity_at) are deleted.
RETENTION_DAYS=180

# kpi_events older than this (by created_at) are deleted. Also governs the
# dashboard/admin AI-usage rows (ai_usage rows with no conversation); chat
# AI-usage rows cascade with their conversation under RETENTION_DAYS.
KPI_RETENTION_DAYS=180

# Idle 'active' conversations older than this are flipped to 'abandoned'.
ABANDON_AFTER_MINUTES=30

# Grace period before unsubscribed/suppressed email_captures are purged.
# The suppression_list entry itself is always kept to honour the opt-out.
SUPPRESSED_CAPTURE_PURGE_DAYS=30

# Correspondence (email_messages, by occurred_at) is purged on its OWN schedule
# — it's its own data category (Korrespondenz / Art. 6(1)(b)/(f)), not marketing
# consent. Default 365 (longer than the analytics window; pending Legal sign-off).
CORRESPONDENCE_RETENTION_DAYS=365

# Free-text customer feedback (feedback table, by created_at) — can carry
# user-supplied PII, so it doesn't live forever. Default 365. 0 disables.
FEEDBACK_RETENTION_DAYS=365

# Storage limitation (Art. 5(1)(e)): purge IDENTIFIED but DORMANT customers whose
# last_seen_at is older than this — EXCEPT those holding an active marketing
# consent ('confirmed'/'pending'), which is its own basis to retain. Their
# conversations/correspondence return to pseudonymous rows (ON DELETE SET NULL)
# and their OAuth tokens cascade away. Conservative 3-year (1095) default; the
# exact window is a policy call — confirm with Legal. 0 disables.
CUSTOMER_INACTIVITY_RETENTION_DAYS=1095

# Admin PII-access audit log (admin_access_log, by occurred_at) — a security
# record of which customer's data an operator pulled. Default 730 (2 years).
# 0 disables.
ADMIN_ACCESS_LOG_RETENTION_DAYS=730
