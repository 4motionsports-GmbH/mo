# Anthropic Claude API key — powers the chat model in /api/chat
ANTHROPIC_API_KEY=

# OpenAI API key — used to embed the user query for product retrieval
OPENAI_API_KEY=

# Comma-separated list of browser origins allowed to call the API
# (CORS allowlist). Falls back to https://www.motionsports.de,https://motionsports.de
ALLOWED_ORIGINS=https://www.motionsports.de,https://motionsports.de

# Shared secret the frontend must send in the `x-ms-chat-key` header
# on every /api/chat and /api/contact request. Generate a long random string.
CHAT_SHARED_SECRET=

# Upstash Redis REST URL — used by the per-client rate limiter
# (20 requests / 60 s sliding window). If unset, rate limiting no-ops.
# The Vercel-Upstash Marketplace integration injects KV_REST_API_URL /
# KV_REST_API_TOKEN automatically; the rate limiter accepts either pair.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token — paired with UPSTASH_REDIS_REST_URL above
UPSTASH_REDIS_REST_TOKEN=

# Resend API key — used by /api/contact to deliver contact-form submissions
# as email. If unset, submissions are logged to stdout (local dev fallback).
RESEND_API_KEY=

# Inbox that receives contact-form submissions (e.g. vertrieb@motionsports.de).
# Must be set together with RESEND_API_KEY for email to be sent.
CONTACT_TO_EMAIL=

# Verified Resend sender (e.g. "Motion Sports <kontakt@motionsports.de>").
# The domain must be verified in your Resend dashboard.
CONTACT_FROM_EMAIL=

# --- Shopify catalog sync ---------------------------------------------------
# As of January 2026 the Shopify admin no longer exposes a static shpat_
# access token. Apps created in the Developer Dashboard get a Client ID and
# Client Secret (shpss_…); the backend exchanges them for a short-lived
# Admin API token via the OAuth client-credentials grant. Run
# `npm run verify:shopify` after filling these in to confirm auth works.

# The store's *.myshopify.com domain (NOT the public domain).
# Example: motion-sports.myshopify.com
SHOPIFY_STORE_DOMAIN=

# App Client ID from the Shopify Developer Dashboard.
SHOPIFY_CLIENT_ID=

# App Client Secret (shpss_…) from the Shopify Developer Dashboard.
SHOPIFY_CLIENT_SECRET=

# Admin API version to target. Use the current stable, e.g. 2026-04.
# See https://shopify.dev/docs/api/usage/versioning
SHOPIFY_API_VERSION=2026-04

# --- Catalog sync storage + scheduling --------------------------------------
# Vercel Blob token used to read/write the cached catalog + embeddings
# (keys: catalog/product-catalog.json, catalog/product-embeddings.json).
# If unset the runtime falls back to the committed JSON in src/data/.
BLOB_READ_WRITE_TOKEN=

# Shared secret Vercel Cron sends as `Authorization: Bearer <secret>` to
# /api/cron/sync-catalog. Generate a long random string.
CRON_SECRET=

# --- Observability (optional) ----------------------------------------------
# Sentry DSN for server-side error capture. If unset, Sentry is skipped
# silently and errors are logged to stdout only — the routes never crash on
# missing observability config.
SENTRY_DSN=

# --- Database (Vercel Postgres / Neon) --------------------------------------
# As of 2026 Vercel Postgres is the Neon native integration. Installing it
# from the Vercel Marketplace injects these automatically — you normally do
# NOT set them by hand in production. They're listed here so local dev and the
# `npm run db:migrate` script know what to provide.
#
# Pooled connection (used by the serverless routes for short queries). The
# integration also injects the legacy POSTGRES_URL with the same value.
DATABASE_URL=

# Direct/unpooled connection (used by migrations and other DDL-heavy work).
# The integration also injects the legacy POSTGRES_URL_NON_POOLING. If unset,
# the pooled URL is used as a fallback.
DATABASE_URL_UNPOOLED=

# Shared secret Vercel Cron sends as `Authorization: Bearer <secret>` to
# /api/cron/retention. Reuses the same value as CRON_SECRET in practice;
# kept as its own name here for clarity. If only CRON_SECRET is set, that is
# used for both cron endpoints.
# (No separate var required — /api/cron/retention also accepts CRON_SECRET.)
