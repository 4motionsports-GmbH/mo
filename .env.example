# Anthropic Claude API key — powers the chat model in /api/chat
ANTHROPIC_API_KEY=

# OpenAI API key — used to embed the user query for product retrieval
OPENAI_API_KEY=

# Comma-separated list of browser origins allowed to call the API
# (CORS allowlist). Falls back to https://www.motionsports.de,https://motionsports.de
ALLOWED_ORIGINS=https://www.motionsports.de,https://motionsports.de

# Shared secret the frontend must send in the `x-ms-chat-key` header
# on every /api/chat and /api/contact request. Generate a long random string.
CHAT_SHARED_SECRET=

# Upstash Redis REST URL — used by the per-client rate limiter
# (20 requests / 60 s sliding window). If unset, rate limiting no-ops.
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token — paired with UPSTASH_REDIS_REST_URL above
UPSTASH_REDIS_REST_TOKEN=
